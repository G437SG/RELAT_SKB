{
  "name": "relatorio-clientes-online",
  "version": "1.0.0",
  "description": "Sistema de relatórios para clientes online - Formulário Projeto Arquitetônico",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "serve-static": "npx http-server formulario-projeto-arquitetonico/public -p 3000 -c-1",
    "serve-simple": "npx serve formulario-projeto-arquitetonico/public -l 3000",
    "check-structure": "dir /s /b *.html *.js *.css",
    "install-global": "npm install -g http-server serve",
    "test": "echo \"Testando estrutura...\" && node -e \"console.log('Node.js funcionando!');\""
  },
  "keywords": [
    "relatorio",
    "arquitetura",
    "clientes",
    "formulario",
    "skborges",
    "express",
    "nodejs"
  ],
  "author": "SKBORGES",
  "license": "MIT",
  "dependencies": {
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "helmet": "^7.0.0",
    "multer": "^2.0.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "http-server": "^14.1.1",
    "nodemon": "^3.0.1",
    "serve": "^14.2.0"
  },
  "engines": {
    "node": ">=14.0.0",
    "npm": ">=6.0.0"
  }
}
